# ============================================================
# AutoNomX .gitignore
# ============================================================

# ---- .NET ----
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
[Dd]ebug/
[Rr]elease/
x64/
x86/
*.nupkg
*.snupkg
project.lock.json
*.nuget.props
*.nuget.targets
.vs/
launchSettings.json

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg
.venv/
venv/
ENV/
.python-version
*.pyo
*.pyd

# ---- Generated gRPC code ----
src/**/Protos/Generated/
agents/autonomx_agents/generated/

# ---- IDE ----
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Docker ----
docker-compose.override.yml

# ---- Environment ----
.env
.env.local
.env.*.local
!.env.example

# ---- Workspace (runtime project files) ----
workspace/*
!workspace/.gitkeep

# ---- Logs ----
logs/
*.log
nohup.out

# ---- Test ----
coverage/
*.coverage
htmlcov/
.pytest_cache/
TestResults/

# ---- Misc ----
*.bak
*.tmp
*.temp
